<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#030F1C"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="J.A.R.V.I.S"
        android:textColor="#00D4FF"
        android:textSize="28sp"
        android:gravity="center"
        android:letterSpacing="0.4"
        android:paddingTop="24dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hazir"
        android:textColor="#00FF88"
        android:textSize="12sp"
        android:gravity="end"
        android:paddingBottom="8dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#C8E6FF"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnMic"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="MIC"
            android:textSize="10sp"
            android:backgroundTint="#0A2A3A" />

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:hint="Komut girin..."
            android:textColor="#C8E6FF"
            android:textColorHint="#4A7FA5"
            android:background="#0A1929"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:inputType="text"
            android:maxLines="2" />

        <Button
            android:id="@+id/btnSend"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="GON"
            android:textSize="10sp"
            android:backgroundTint="#00D4FF" />
    </LinearLayout>

</LinearLayout>
